IMAGE_MODEL=qwen3-8b-instruct
TRANSLATION_MODEL=nemotron-3-nano
IMAGE_MODEL_URL=https://example.com/image-model/v1
TRANSLATION_MODEL_URL=https://example.com/translation-model/v1
CANVAS_WIDTH=1000
CANVAS_HEIGHT=1000
DEFAULT_TRANSLATE_LANGUAGE=english
PORT=8000

# Sampler settings for qwen3_instruct
QWEN3_INSTRUCT_SAMPLER_TEMPERATURE=0.7
QWEN3_INSTRUCT_SAMPLER_TOP_P=0.8
QWEN3_INSTRUCT_SAMPLER_TOP_K=20
QWEN3_INSTRUCT_SAMPLER_REPETITION_PENALTY=1.0
QWEN3_INSTRUCT_SAMPLER_PRESENCE_PENALTY=1.5
QWEN3_INSTRUCT_SAMPLER_MAX_TOKENS=16384

# Sampler settings for qwen3_thinking
QWEN3_THINKING_SAMPLER_TEMPERATURE=1.0
QWEN3_THINKING_SAMPLER_TOP_P=0.95
QWEN3_THINKING_SAMPLER_TOP_K=20
QWEN3_THINKING_SAMPLER_REPETITION_PENALTY=1.0
QWEN3_THINKING_SAMPLER_PRESENCE_PENALTY=0.0
QWEN3_THINKING_SAMPLER_MAX_TOKENS=40960

# Sampler settings for image_model
IMAGE_MODEL_SAMPLER_TEMPERATURE=0.7
IMAGE_MODEL_SAMPLER_TOP_P=0.8
IMAGE_MODEL_SAMPLER_TOP_K=20
IMAGE_MODEL_SAMPLER_REPETITION_PENALTY=1.0
IMAGE_MODEL_SAMPLER_PRESENCE_PENALTY=1.5
IMAGE_MODEL_SAMPLER_MAX_TOKENS=16384

# Sampler settings for translation_model
TRANSLATION_MODEL_SAMPLER_TEMPERATURE=0.7
TRANSLATION_MODEL_SAMPLER_TOP_P=0.8
TRANSLATION_MODEL_SAMPLER_TOP_K=20
TRANSLATION_MODEL_SAMPLER_REPETITION_PENALTY=1.0
TRANSLATION_MODEL_SAMPLER_PRESENCE_PENALTY=1.5
TRANSLATION_MODEL_SAMPLER_MAX_TOKENS=16384


# ==============================================================================
# OAuth2 / OpenID Connect Configuration
# ==============================================================================
#
# Option 1: OpenID Connect Discovery (Recommended)
# Provide only the issuer URL - all other endpoints are discovered automatically
#
# OAUTH2_ISSUER=https://your-keycloak-server.com/realms/your-realm
#
# Option 2: Manual Configuration
# Uncomment and configure these if your provider doesn't support .well-known discovery
#
# OAUTH2_AUTHORIZE_URL=https://your-keycloak-server.com/protocol/openid-connect/auth
# OAUTH2_TOKEN_URL=https://your-keycloak-server.com/protocol/openid-connect/token
# OAUTH2_JWKS_URL=https://your-keycloak-server.com/protocol/openid-connect/certs
#
# Common OAuth2 Settings (required for both options)
#
OAUTH2_CLIENT_ID=looking-glass
OAUTH2_CLIENT_SECRET=your-client-secret-here
OAUTH2_REDIRECT_URI=https://your-backend-domain.com/auth/callback
OAUTH2_SCOPES=openid profile email

# Note: OAUTH2_REDIRECT_URI must match exactly what is configured in your OAuth2 provider
# For local development: http://localhost:8000/auth/callback
# For production: https://your-domain.com/auth/callback
#
# Session Secret Key (REQUIRED for OAuth2 state management)
# Generate a secure random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=your-32-byte-random-secret-key-here

# ==============================================================================
# Redis Configuration
# ==============================================================================
#
# Redis URL for persistent access code storage (optional but recommended for production)
# Format: redis://host:port/db or rediss://host:port/db for TLS
# Example: redis://localhost:6379/0
#
# For local development with Docker:
# REDIS_URL=redis://localhost:6379/0
#
# For production with authentication:
# REDIS_URL=redis://:your-redis-password@redis.example.com:6379/0
#
# Access code TTL in seconds (default: 86400 = 24 hours)
# How long access codes remain valid before expiring
# ACCESS_CODE_TTL=86400