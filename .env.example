# LookingGlass Configuration
#
# Copy this file to .env and customize:
#   cp .env.example .env
#
# Most values have sensible defaults — only set what you need to override.
#
# ==============================================================================
# Core Configuration
# ==============================================================================
#
# LLM endpoints for image and translation models
# IMAGE_MODEL_URL=http://image-annotator:8000/v1  (default for docker-compose)
# TRANSLATION_MODEL_URL=<your-translation-endpoint>
#
# Model names
# IMAGE_MODEL=<model-name>
# TRANSLATION_MODEL=<model-name>
#
# Server port
# PORT=8000
#
# Canvas dimensions for image processing
# CANVAS_WIDTH=1000
# CANVAS_HEIGHT=1000
#
# ==============================================================================
# Sampling Parameters
# ==============================================================================
#
# Qwen3 instruct model sampler settings
# QWEN3_INSTRUCT_SAMPLER_TEMPERATURE=0.7
# QWEN3_INSTRUCT_SAMPLER_TOP_P=0.8
# QWEN3_INSTRUCT_SAMPLER_TOP_K=20
# QWEN3_INSTRUCT_SAMPLER_REPETITION_PENALTY=1.0
# QWEN3_INSTRUCT_SAMPLER_PRESENCE_PENALTY=1.5
# QWEN3_INSTRUCT_SAMPLER_MAX_TOKENS=16384
#
# Qwen3 thinking model sampler settings
# QWEN3_THINKING_SAMPLER_TEMPERATURE=1.0
# QWEN3_THINKING_SAMPLER_TOP_P=0.95
# QWEN3_THINKING_SAMPLER_TOP_K=20
# QWEN3_THINKING_SAMPLER_REPETITION_PENALTY=1.0
# QWEN3_THINKING_SAMPLER_PRESENCE_PENALTY=0.0
# QWEN3_THINKING_SAMPLER_MAX_TOKENS=40960
#
# Image model sampler settings
# IMAGE_MODEL_SAMPLER_TEMPERATURE=0.7
# IMAGE_MODEL_SAMPLER_TOP_P=0.8
# IMAGE_MODEL_SAMPLER_TOP_K=20
# IMAGE_MODEL_SAMPLER_REPETITION_PENALTY=1.0
# IMAGE_MODEL_SAMPLER_PRESENCE_PENALTY=1.5
# IMAGE_MODEL_SAMPLER_MAX_TOKENS=16384
#
# Translation model sampler settings
# TRANSLATION_MODEL_SAMPLER_TEMPERATURE=0.7
# TRANSLATION_MODEL_SAMPLER_TOP_P=0.8
# TRANSLATION_MODEL_SAMPLER_TOP_K=20
# TRANSLATION_MODEL_SAMPLER_REPETITION_PENALTY=1.0
# TRANSLATION_MODEL_SAMPLER_PRESENCE_PENALTY=1.5
# TRANSLATION_MODEL_SAMPLER_MAX_TOKENS=16384
#
# ==============================================================================
# Gemma 12b OCR (Optional)
# ==============================================================================
#
# Enable Gemma 12b as an alternative OCR backend
# ENABLE_GEMMA_OCR=false
# GEMMA_OCR_URL=http://172.16.100.189:8010/v1
# GEMMA_OCR_MODEL=gemma-12b
# GEMMA_OCR_TIMEOUT=120
# GEMMA_OCR_MAX_TOKENS=4096
#
# ==============================================================================
# Image Tiling (Optional — improves OCR on large images)
# ==============================================================================
#
# ENABLE_TILING=true
# TILE_TRIGGER_SIZE=1500
# TILE_SIZE=1024
# TILE_OVERLAP_RATIO=0.15
# MERGE_IOU_THRESHOLD=0.5
# TEXT_SIMILARITY_THRESHOLD=0.85
#
# ==============================================================================
# Security (REQUIRED for production)
# ==============================================================================
#
# CORS origins for browser extension (comma-separated)
# WARNING: Set this to actual origins in production — do NOT leave as *
# CORS_ORIGINS=
#
# API key for production
# API_KEY=
