IMAGE_MODEL=qwen3-8b-instruct
TRANSLATION_MODEL=nemotron-3-nano
IMAGE_MODEL_URL=https://example.com/image-model/v1
TRANSLATION_MODEL_URL=https://example.com/translation-model/v1
CANVAS_WIDTH=1000
CANVAS_HEIGHT=1000
DEFAULT_TRANSLATE_LANGUAGE=english
PORT=8000

# Sampler settings for qwen3_instruct
QWEN3_INSTRUCT_SAMPLER_TEMPERATURE=0.7
QWEN3_INSTRUCT_SAMPLER_TOP_P=0.8
QWEN3_INSTRUCT_SAMPLER_TOP_K=20
QWEN3_INSTRUCT_SAMPLER_REPETITION_PENALTY=1.0
QWEN3_INSTRUCT_SAMPLER_PRESENCE_PENALTY=1.5
QWEN3_INSTRUCT_SAMPLER_MAX_TOKENS=16384

# Sampler settings for qwen3_thinking
QWEN3_THINKING_SAMPLER_TEMPERATURE=1.0
QWEN3_THINKING_SAMPLER_TOP_P=0.95
QWEN3_THINKING_SAMPLER_TOP_K=20
QWEN3_THINKING_SAMPLER_REPETITION_PENALTY=1.0
QWEN3_THINKING_SAMPLER_PRESENCE_PENALTY=0.0
QWEN3_THINKING_SAMPLER_MAX_TOKENS=40960

# Sampler settings for image_model
IMAGE_MODEL_SAMPLER_TEMPERATURE=0.7
IMAGE_MODEL_SAMPLER_TOP_P=0.8
IMAGE_MODEL_SAMPLER_TOP_K=20
IMAGE_MODEL_SAMPLER_REPETITION_PENALTY=1.0
IMAGE_MODEL_SAMPLER_PRESENCE_PENALTY=1.5
IMAGE_MODEL_SAMPLER_MAX_TOKENS=16384

# Sampler settings for translation_model
TRANSLATION_MODEL_SAMPLER_TEMPERATURE=0.7
TRANSLATION_MODEL_SAMPLER_TOP_P=0.8
TRANSLATION_MODEL_SAMPLER_TOP_K=20
TRANSLATION_MODEL_SAMPLER_REPETITION_PENALTY=1.0
TRANSLATION_MODEL_SAMPLER_PRESENCE_PENALTY=1.5
TRANSLATION_MODEL_SAMPLER_MAX_TOKENS=16384



# ==============================================================================
# Image Tiling Configuration
# ==============================================================================
#
# Adaptive tiling splits large images into overlapping tiles for better text detection.
# This improves accuracy on large images where VLMs often miss text at edges.
#
# Enable/disable adaptive tiling for large images (default: true)
# Set to false to always use single-pass processing (faster but less accurate)
# ENABLE_TILING=true
#
# Maximum image dimension before tiling is triggered (default: 1500)
# Images with max(width, height) > this value will be tiled
# TILE_TRIGGER_SIZE=1500
#
# Target tile size in pixels (default: 1024)
# Matches typical VLM input size for optimal detection
# TILE_SIZE=1024
#
# Overlap ratio between adjacent tiles (default: 0.15 = 15%)
# Higher overlap reduces edge misses but increases processing time
# TILE_OVERLAP_RATIO=0.15
#
# IoU threshold for merging overlapping bounding boxes (default: 0.5)
# Boxes with IoU > this value are merged as duplicates
# MERGE_IOU_THRESHOLD=0.5
#
# Text similarity threshold for deduplication (default: 0.85)
# Text strings with similarity > this value are considered duplicates
# TEXT_SIMILARITY_THRESHOLD=0.85