# LookingGlass Configuration
#
# Copy this file to .env and customize:
#   cp .env.example .env
#
# Most values have sensible defaults — only set what you need to override.
#
# ==============================================================================
# Required Configuration
# ==============================================================================
#
# LLM endpoints for image and translation models
IMAGE_MODEL_URL=
TRANSLATION_MODEL_URL=
#
# Model names
IMAGE_MODEL=
TRANSLATION_MODEL=
#
# ==============================================================================
# Application Settings (optional, have defaults)
# ==============================================================================
#
# Server port (default: 8000)
# PORT=8000
#
# Logging level (default: INFO)
# LOG_LEVEL=INFO
#
# CORS origins for browser extension (comma-separated, default: *)
# WARNING: Set this to actual origins in production — do NOT leave as *
# CORS_ORIGINS=*
#
# API key for production (optional — leave unset to disable auth)
# API_KEY=
#
# Default translation language (default: english)
# DEFAULT_TRANSLATE_LANGUAGE=english
#
# Translation enable_thinking mode (Qwen-specific, default: false)
# TRANSLATION_ENABLE_THINKING=false
#
# ==============================================================================
# OCR Provider Configuration
# ==============================================================================
#
# Select the OCR / vision provider (default: glm_ocr)
# Available: glm_ocr, gemma, vlm
# OCR_PROVIDER=glm_ocr
#
# GLM-OCR timeout (default: 60)
# GLM_OCR_TIMEOUT=60
#
# Gemma 12b OCR (OpenAI-compatible API, optional)
# GEMMA_OCR_URL=http://172.16.100.189:8010/v1
# GEMMA_OCR_MODEL=gemma-12b
# GEMMA_OCR_TIMEOUT=120
# GEMMA_OCR_MAX_TOKENS=4096
#
# Per-provider generic overrides (optional — override provider-specific fields)
# OCR_PROVIDER_GLM_OCR_URL=http://localhost:8000/v1
# OCR_PROVIDER_GLM_OCR_MODEL=my-glm-model
# OCR_PROVIDER_GEMMA_URL=http://localhost:8010/v1
# OCR_PROVIDER_GEMMA_MODEL=gemma-12b
#
# Translation timeout (higher for thinking mode, default: 600)
# TRANSLATION_TIMEOUT=600
#
# ==============================================================================
# Legacy Deprecated Settings
# ==============================================================================
# These are still read but emit deprecation warnings. Use OCR_PROVIDER instead.
# ENABLE_GLM_OCR=false
# ENABLE_GEMMA_OCR=false
