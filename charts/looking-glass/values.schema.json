{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Looking Glass Helm Chart Values",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "default": 1,
      "description": "Number of replicas"
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "description": "Docker image repository"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"],
          "description": "Image pull policy"
        },
        "tag": {
          "type": "string",
          "description": "Image tag (defaults to appVersion)"
        }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "canvasWidth": {
          "type": "string",
          "description": "Canvas width for image processing"
        },
        "canvasHeight": {
          "type": "string",
          "description": "Canvas height for image processing"
        },
        "defaultTranslateLanguage": {
          "type": "string",
          "description": "Default translation target language"
        },
        "port": {
          "type": "string",
          "description": "Server port"
        }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "imageModel": {
          "type": "string",
          "description": "Image model name"
        },
        "translationModel": {
          "type": "string",
          "description": "Translation model name"
        },
        "imageModelUrl": {
          "type": "string",
          "description": "Image model API URL"
        },
        "translationModelUrl": {
          "type": "string",
          "description": "Translation model API URL"
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "className": {
          "type": "string"
        },
        "hosts": {
          "type": "array"
        },
        "tls": {
          "type": "array"
        }
      }
    },
    "pdb": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "minAvailable": {
          "type": "integer"
        }
      }
    }
  }
}
